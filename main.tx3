party Owner;

party Beneficiary;

policy Vault = 0x3d6a08a2161b3c365101b4abd92583c32a6ef2b804431d53ebc26bfe;

type VestingParams {
  lock_until: Int,
  owner: Bytes,
  beneficiary: Bytes,
}

tx lock(
    quantity: Int,
    until_posix: Int,
) {
    input source {
        from: Owner,
        min_amount: Ada(quantity),
    }

    output {
        to: Vault,
        amount: Ada(quantity),
        datum: VestingParams {
            lock_until: until_posix,
            owner: Owner,
            beneficiary: Beneficiary,
        },
    }

    output {
        to: Owner,
        amount: source - Ada(quantity) - fees,
    }

}

tx unlock(
    locked: UtxoRef,
    current_slot: Int,
) {
    input source {
        from: Vault,
        ref: locked,
        datum_is: VestingParams,
        redeemer: (),
    }

    input gas {
        from: Beneficiary,
        min_amount: fees,
    }

    collateral {
        from: Beneficiary,
        min_amount: fees,
    }
    
    output {
        to: Beneficiary,
        amount: source + gas - fees,
    }

    validity {
        since_slot: current_slot,
    }

    signers {
        Beneficiary,
    }

    cardano::plutus_witness {
        version: 3,
        script: ,
    }
}


tx reclaim(
    locked: UtxoRef,
) {
    input source {
        from: Vault,
        ref: locked,
        datum_is: VestingParams,
        redeemer: (),
    }

    input gas {
        from: Owner,
        min_amount: fees,
    }

    collateral {
        from: Owner,
        min_amount: fees,
    }
    
    output {
        to: Owner,
        amount: source + gas - fees,
    }

    signers {
        Owner,
    }

    cardano::plutus_witness {
        version: 3,
        script: ,
    }
}

