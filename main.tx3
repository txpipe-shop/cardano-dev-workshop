party Initiator;
party CurrentRecipient;
party NextRecipient;

policy Vault = 0xe5baebb5a7aaea7305ebe17b394324c96a6ccbfd143b39792686a29d;

type VaultDatum {
  current_recipient: Bytes,
}

tx lock(
    total_lock: Int,
) {
    input source {
        from: Initiator,
        min_amount: fees + Ada(2000000 + total_lock),
    }

    output {
        to: Vault,
        amount: Ada(2000000 + total_lock),
        datum: VaultDatum {
            current_recipient: CurrentRecipient,
        },
    }

    output {
        to: Initiator,
        amount: source - fees - Ada(2000000 + total_lock),
    }
}

tx claim(
    vault_ref: UtxoRef,
    current_amount: Int,
){
    input vault {
        from: Vault,
        ref: vault_ref,
        datum_is: VaultDatum,
        redeemer: (),
    }

    input gas {
        from: CurrentRecipient,
        min_amount: fees,
    }

    collateral {
        from: CurrentRecipient,
        min_amount: Ada(5000000),
    }

    output payment {
        to: CurrentRecipient,
        amount: Ada(current_amount) + gas - fees,
    }

    output {
        to: Vault,
        amount: vault - Ada(current_amount),
        datum: VaultDatum {
            current_recipient: NextRecipient,
        },
    }

    cardano::plutus_witness {
        version: 3,
        script: ,
    }
}

