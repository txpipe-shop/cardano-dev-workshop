party Maker;
party Taker;
party Recipient;

policy Order = 0x215600ed91632ca114554f8b8bc1e116692ddf83e1a78a1d144b076b;

type OrderDatum {
  asset_requested_policy: Bytes,
  asset_requested_name: Bytes,
  amount_requested: Int,
  recipient: Bytes,
}

tx place_order(
    offered_policy: Bytes,
    offered_name: Bytes,
    offered_amount: Int,
    requested_policy: Bytes,
    requested_name: Bytes,
    requested_amount: Int,
) {
    input source {
        from: Maker,
        min_amount: fees + Ada(2000000) + AnyAsset(offered_policy, offered_name, offered_amount),
    }

    output {
        to: Order,
        amount: Ada(2000000) + AnyAsset(offered_policy, offered_name, offered_amount),
        datum: OrderDatum {
            asset_requested_policy: requested_policy,
            asset_requested_name: requested_name,
            amount_requested: requested_amount,
            recipient: Recipient,
        },
    }

    output {
        to: Maker,
        amount: source - (fees + Ada(2000000) + AnyAsset(offered_policy, offered_name, offered_amount)),
    }
}

tx swap(
    order_ref: UtxoRef,
    requested_policy: Bytes,
    requested_name: Bytes,
    requested_amount: Int,
){
    input order {
        from: Order,
        ref: order_ref,
        datum_is: OrderDatum,
        redeemer: (),
    }

    input trade {
        from: Taker,
        min_amount: fees + Ada(2000000) + AnyAsset(requested_policy, requested_name, requested_amount),
    }

    collateral {
        from: Taker,
        min_amount: Ada(5000000),
    }

    output payment {
        to: Recipient,
        amount: Ada(2000000) + AnyAsset(order.asset_requested_policy, order.asset_requested_name, order.amount_requested),
    }

    output {
        to: Taker,
        amount: order + trade - ( fees + Ada(2000000) + AnyAsset(order.asset_requested_policy, order.asset_requested_name, order.amount_requested)),
    }

    cardano::plutus_witness {
        version: 3,
        script: ,
    }
}

