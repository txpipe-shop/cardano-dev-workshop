party Initiator;
party CurrentRecipient;
party NextRecipient;

policy Vault = 0x3b3fc0c0062fcf72dd79c4749a8a7e92eed4f7af0822b2104641eb07;

type VaultDatum {
  current_recipient: Bytes,
}

tx lock(
    total_lock: Int,
) {
    input source {
        from: Initiator,
        min_amount: fees + Ada(total_lock),
    }

    output {
        to: Vault,
        amount: Ada(total_lock),
        datum: VaultDatum {
            current_recipient: CurrentRecipient,
        },
    }

    output {
        to: Initiator,
        amount: source - fees - Ada(total_lock),
    }
}

tx claim(
    vault_ref: UtxoRef,
    current_amount: Int,
){
    input vault {
        from: Vault,
        ref: vault_ref,
        datum_is: VaultDatum,
        redeemer: (),
    }

    input gas {
        from: CurrentRecipient,
        min_amount: fees,
    }

    collateral {
        from: CurrentRecipient,
        min_amount: Ada(5000000),
    }

    signers {
        CurrentRecipient,
    }

    output {
        to: Vault,
        amount: vault - Ada(current_amount),
        datum: VaultDatum {
            current_recipient: NextRecipient,
        },
    }

    output payment {
        to: CurrentRecipient,
        amount: Ada(current_amount) + gas - fees,
    }

    cardano::plutus_witness {
        version: 3,
        script: ,
    }
}

